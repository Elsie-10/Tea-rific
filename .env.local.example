# Copy this file to .env.local and fill in real values before running the app locally

# MongoDB connection string (required for API routes)
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.mongodb.net/tea-terrific?retryWrites=true&w=majority

# NextAuth settings
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_string

# Optional: base URL used in some API callbacks
NEXTAUTH_URL_INTERNAL=http://localhost:3000
